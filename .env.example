# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Services
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
# openai is the default image generator; set to gemini to force Gemini.
IMAGE_PROVIDER=openai
OPENAI_IMAGE_MODEL=gpt-image-1

# Social Platform OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Vercel Cron
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Video Creator (Veo 3.1 Fast via GOOGLE_AI_API_KEY above)
# Hard cap per video in USD. Default: 6. Lower this for tighter control.
VIDEO_COST_CAP_USD=6
# Remotion Lambda — leave UNSET to use the fallback composer (returns the
# first Veo scene as-is, no stitching/overlays/music). Set all four to
# enable full server-side compositing. Deploy with `npx remotion lambda
# sites create` and `npx remotion lambda functions deploy`.
# REMOTION_SERVE_URL=
# REMOTION_LAMBDA_FUNCTION_NAME=
# REMOTION_AWS_REGION=us-east-1
# REMOTION_AWS_ACCESS_KEY_ID=
# REMOTION_AWS_SECRET_ACCESS_KEY=

# Screenshot Capture — works out of the box with local Puppeteer (no key needed).
# Optionally set ONE of these for faster captures via external API:
# BROWSERLESS_API_KEY=        # browserless.io free tier: 1,000/month
# SCREENSHOTONE_API_KEY=      # screenshotone.com free tier: 100/month

# --- Not yet used in code (reserved for future features) ---
# ANTHROPIC_API_KEY=
# IMAGEKIT_PUBLIC_KEY=
# IMAGEKIT_PRIVATE_KEY=
# IMAGEKIT_URL_ENDPOINT=
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# NEXT_PUBLIC_PADDLE_SELLER_ID=
