      "feat1Desc": "\u05d4\u05e2\u05dc\u05d4 \u05e0\u05db\u05e1\u05d9 \u05de\u05d5\u05ea\u05d2, \u05de\u05d3\u05e8\u05d9\u05db\u05d9 \u05d8\u05d5\u05df \u05d5\u05de\u05d9\u05d3\u05e2 \u05ea\u05d7\u05e8\u05d5\u05ea\u05d9. MarketPilot \u05dc\u05d5\u05de\u05d3 \u05d0\u05ea \u05d4-DNA \u05e9\u05dc \u05d4\u05de\u05d5\u05ea\u05d2 \u05e9\u05dc\u05da \u05d5\u05e9\u05d5\u05de\u05e8 \u05e2\u05dc \u05de\u05e1\u05e8 \u05d0\u05d7\u05d9\u05d3 \u05d1\u05db\u05dc \u05e4\u05d5\u05e1\u05d8.",
      "feat2Title": "\u05de\u05e0\u05d5\u05e2 \u05db\u05d9\u05e9\u05d5\u05e8\u05d9 AI",
      "feat2Desc": "\u05e1\u05d5\u05db\u05e0\u05d9 AI \u05de\u05ea\u05de\u05d7\u05d9\u05dd \u05dc\u05e7\u05d5\u05e4\u05d9\u05e8\u05d9\u05d9\u05d8\u05d9\u05e0\u05d2, \u05d9\u05e6\u05d9\u05e8\u05ea \u05ea\u05de\u05d5\u05e0\u05d5\u05ea \u05d5\u05d0\u05e1\u05d8\u05e8\u05d8\u05d2\u05d9\u05d9\u05ea \u05e7\u05de\u05e4\u05d9\u05d9\u05e0\u05d9\u05dd. \u05db\u05dc \u05db\u05d9\u05e9\u05d5\u05e8 \u05de\u05d0\u05d5\u05de\u05df \u05e2\u05dc \u05e9\u05d9\u05d8\u05d5\u05ea \u05e2\u05d1\u05d5\u05d3\u05d4 \u05de\u05d5\u05d1\u05d9\u05dc\u05d5\u05ea.",
      "feat3Title": "\u05dc\u05d5\u05d7 \u05ea\u05d5\u05db\u05df",
      "feat3Desc": "\u05ea\u05db\u05e0\u05df, \u05ea\u05d6\u05de\u05df \u05d5\u05e4\u05e8\u05e1\u05dd \u05d1\u05db\u05dc \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d5\u05ea \u05de\u05dc\u05d5\u05d7 \u05e9\u05e0\u05d4 \u05d0\u05d7\u05d3 \u05e2\u05dd \u05d2\u05e8\u05d9\u05e8\u05d4 \u05d5\u05e9\u05d7\u05e8\u05d5\u05e8. \u05dc\u05e2\u05d5\u05dc\u05dd \u05dc\u05d0 \u05ea\u05e4\u05e1\u05e4\u05e1 \u05d7\u05dc\u05d5\u05df \u05e4\u05e8\u05e1\u05d5\u05dd.",
      "feat4Title": "\u05e4\u05e8\u05e1\u05d5\u05dd \u05e8\u05d1-\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d9",
      "feat4Desc": "\u05d7\u05d1\u05e8 \u05d0\u05ea Twitter/X, LinkedIn, Instagram \u05d5\u05e2\u05d5\u05d3. \u05e4\u05e8\u05e1\u05dd \u05d1\u05d5-\u05d6\u05de\u05e0\u05d9\u05ea \u05e2\u05dd \u05e2\u05d9\u05e6\u05d5\u05d1 \u05de\u05d5\u05ea\u05d0\u05dd \u05dc\u05db\u05dc \u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4.",
      "feat5Title": "\u05ea\u05d2\u05d5\u05d1\u05d4 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9\u05ea",
      "feat5Desc": "\u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05d7\u05db\u05de\u05d5\u05ea \u05dc\u05ea\u05d2\u05d5\u05d1\u05d5\u05ea \u05d5\u05d4\u05d5\u05d3\u05e2\u05d5\u05ea \u05d1\u05e7\u05d5\u05dc \u05d4\u05de\u05d5\u05ea\u05d2 \u05e9\u05dc\u05da. \u05e9\u05de\u05d5\u05e8 \u05e2\u05dc \u05de\u05e2\u05d5\u05e8\u05d1\u05d5\u05ea \u05e2\u05dd \u05d4\u05e7\u05d4\u05dc 24/7 \u05d1\u05dc\u05d9 \u05dc\u05d4\u05e0\u05d9\u05d3 \u05d0\u05e6\u05d1\u05e2.",
      "feat6Title": "\u05d0\u05e0\u05dc\u05d9\u05d8\u05d9\u05e7\u05ea \u05e7\u05de\u05e4\u05d9\u05d9\u05e0\u05d9\u05dd",
      "feat6Desc": "\u05e2\u05e7\u05d5\u05d1 \u05d0\u05d7\u05e8 \u05d7\u05e9\u05d9\u05e4\u05d4, \u05de\u05e2\u05d5\u05e8\u05d1\u05d5\u05ea \u05d5\u05d4\u05de\u05e8\u05d5\u05ea \u05dc\u05db\u05dc \u05e7\u05de\u05e4\u05d9\u05d9\u05df. \u05ea\u05d5\u05d1\u05e0\u05d5\u05ea \u05de\u05d1\u05d5\u05e1\u05e1\u05d5\u05ea AI \u05d7\u05d5\u05e9\u05e4\u05d5\u05ea \u05de\u05d4 \u05e2\u05d5\u05d1\u05d3 \u05d5\u05dc\u05de\u05d4."
    },
    "steps": {
      "title": "\u05de\u05d5\u05db\u05df \u05dc\u05e4\u05e2\u05d5\u05dc\u05d4 \u05ea\u05d5\u05da \u05d3\u05e7\u05d5\u05ea",
      "subtitle": "\u05e9\u05dc\u05d5\u05e9\u05d4 \u05e6\u05e2\u05d3\u05d9\u05dd \u05de\u05d0\u05e4\u05e1 \u05d5\u05e2\u05d3 \u05de\u05e0\u05d5\u05e2 \u05e9\u05d9\u05d5\u05d5\u05e7 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9 \u05dc\u05d7\u05dc\u05d5\u05d8\u05d9\u05df.",
      "step1Title": "\u05e6\u05d5\u05e8 \u05d0\u05ea \u05d4\u05e4\u05e8\u05d5\u05d9\u05e7\u05d8",
      "step1Desc": "\u05d4\u05e7\u05dd \u05e1\u05d1\u05d9\u05d1\u05ea \u05e2\u05d1\u05d5\u05d3\u05d4 \u05dc\u05de\u05d5\u05ea\u05d2 \u05e9\u05dc\u05da. \u05d7\u05d1\u05e8 \u05d7\u05e9\u05d1\u05d5\u05e0\u05d5\u05ea \u05d7\u05d1\u05e8\u05ea\u05d9\u05d9\u05dd \u05d5\u05d4\u05e2\u05dc\u05d4 \u05d4\u05e0\u05d7\u05d9\u05d5\u05ea \u05de\u05d5\u05ea\u05d2 \u05ea\u05d5\u05da \u05d3\u05e7\u05d5\u05ea.",
      "step2Title": "\u05d0\u05de\u05df \u05d0\u05ea \u05d4-AI \u05e2\u05dc \u05d4\u05de\u05d5\u05ea\u05d2",
      "step2Desc": "\u05d4\u05d6\u05df \u05dc-MarketPilot \u05d0\u05ea \u05d4\u05d8\u05d5\u05df, \u05d4\u05d6\u05d4\u05d5\u05ea \u05d4\u05d5\u05d9\u05d6\u05d5\u05d0\u05dc\u05d9\u05ea \u05d5\u05e7\u05d4\u05dc \u05d4\u05d9\u05e2\u05d3 \u05e9\u05dc\u05da. \u05d4-AI \u05dc\u05d5\u05de\u05d3 \u05de\u05d4 \u05d4\u05d5\u05e4\u05da \u05d0\u05ea \u05d4\u05de\u05d5\u05ea\u05d2 \u05e9\u05dc\u05da \u05dc\u05d9\u05d9\u05d7\u05d5\u05d3\u05d9.",
      "step3Title": "\u05e6\u05d5\u05e8 \u05d5\u05ea\u05d6\u05de\u05df \u05ea\u05d5\u05db\u05df",
      "step3Desc": "\u05e6\u05d5\u05e8 \u05e7\u05de\u05e4\u05d9\u05d9\u05e0\u05d9\u05dd \u05d1\u05e4\u05e7\u05d5\u05d3\u05d4 \u05d0\u05d7\u05ea. \u05e1\u05e7\u05d5\u05e8, \u05e9\u05e4\u05e8 \u05d5\u05ea\u05d6\u05de\u05df \u05e4\u05d5\u05e1\u05d8\u05d9\u05dd \u05d1\u05db\u05dc \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d5\u05ea \u05d1\u05d1\u05ea \u05d0\u05d7\u05ea."
    },
    "cta": {
      "title": "\u05de\u05d5\u05db\u05e0\u05d9\u05dd \u05dc\u05e0\u05d5\u05d5\u05d8 \u05d0\u05ea \u05d4\u05e6\u05de\u05d9\u05d7\u05d4?",
      "subtitle": "\u05d4\u05e6\u05d8\u05e8\u05e4\u05d5 \u05dc\u05d0\u05dc\u05e4\u05d9 \u05de\u05e9\u05d5\u05d5\u05e7\u05d9\u05dd \u05e9\u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd \u05d1-MarketPilot \u05db\u05d3\u05d9 \u05dc\u05d7\u05e1\u05d5\u05da \u05d6\u05de\u05df \u05d5\u05dc\u05d4\u05e9\u05d9\u05d2 \u05ea\u05d5\u05e6\u05d0\u05d5\u05ea.",
      "getStartedFree": "\u05d4\u05ea\u05d7\u05dc \u05d1\u05d7\u05d9\u05e0\u05dd",
